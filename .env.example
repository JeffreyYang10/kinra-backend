PORT=8787

# Optional. If set, Saku clients must send `x-saku-api-key`.
SAKU_API_KEY=
SAKU_MARKET_CLIENT_KEY=

# Kinra account backend. For a single-node beta server, this JSON file stores
# users and hashed sessions. Use a persistent disk in production, or replace
# this store with Postgres before scaling horizontally/serverlessly.
AUTH_DATA_PATH=./data/kinra-auth.json
SESSION_TTL_HOURS=2160
APPLE_BUNDLE_ID=com.jeffreyyang.saku
APPLE_SERVICE_ID=

# PSA credentials belong on this server only. Never put them in the iOS app.
# Prefer password grant or the exact auth flow PSA documents for your account.
PSA_AUTH_MODE=password
PSA_TOKEN_URL=
PSA_CLIENT_ID=
PSA_CLIENT_SECRET=
PSA_USERNAME=
PSA_PASSWORD=
PSA_SCOPE=

# For short local smoke tests only. Rotate any token pasted into chat.
PSA_ACCESS_TOKEN=

# Fill these from PSA's logged-in API documentation.
PSA_API_BASE_URL=https://api.psacard.com
PSA_CERT_PATH_TEMPLATE=/publicapi/cert/GetByCertNumber/{certNumber}
PSA_CERT_IMAGES_PATH_TEMPLATE=/publicapi/cert/GetImagesByCertNumber/{certNumber}

# eBay Browse API powers active listing floor and active supply.
# Marketplace Insights is limited-access; enable it only if eBay grants access.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_OAUTH_SCOPE=https://api.ebay.com/oauth/api_scope
EBAY_ENABLE_MARKETPLACE_INSIGHTS=false
EBAY_INSIGHTS_OAUTH_SCOPE=https://api.ebay.com/oauth/api_scope https://api.ebay.com/oauth/api_scope/buy.marketplace.insights
EBAY_BROWSE_BASE_URL=https://api.ebay.com/buy/browse/v1
EBAY_INSIGHTS_BASE_URL=https://api.ebay.com/buy/marketplace_insights/v1_beta

# TCGplayer pricing requires existing developer API access.
TCGPLAYER_PUBLIC_KEY=
TCGPLAYER_PRIVATE_KEY=
TCGPLAYER_ACCESS_TOKEN=
TCGPLAYER_API_BASE_URL=https://api.tcgplayer.com/v1.39.0
TCGPLAYER_PRICING_BASE_URL=https://api.tcgplayer.com/pricing
TCGPLAYER_TOKEN_URL=https://api.tcgplayer.com/token

# PriceCharting contributes ungraded and graded card market values.
# The token must stay server-side; PriceCharting authenticates with `t=<token>`.
PRICECHARTING_API_TOKEN=
PRICECHARTING_API_BASE_URL=https://www.pricecharting.com

# RapidAPI Graded Card Census API powers PSA population reports.
# https://rapidapi.com/lulzasaur9192/api/graded-card-census-api
GRADED_CENSUS_RAPIDAPI_KEY=
GRADED_CENSUS_RAPIDAPI_HOST=graded-card-census-api.p.rapidapi.com
GRADED_CENSUS_API_BASE_URL=https://graded-card-census-api.p.rapidapi.com

# Public/no-credential pricing sources used by /market/quote when possible.
POKEMON_TCG_API_BASE_URL=https://api.pokemontcg.io/v2
YUGIOH_API_BASE_URL=https://db.ygoprodeck.com/api/v7
SCRYFALL_API_BASE_URL=https://api.scryfall.com

# Useful during endpoint mapping, but keep false in production.
INCLUDE_RAW_PSA_RESPONSE=false
